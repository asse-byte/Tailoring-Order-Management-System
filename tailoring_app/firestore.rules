// =============================================================================
// Couture Mali — Firestore security rules
// =============================================================================
// Two operating roles only:
//   • admin     (le Gérant)     — full access to everything.
//   • secretary (la Secrétaire) — daily operations, but NO financial data.
//
// Financial isolation is enforced HERE, server-side. Hiding buttons in the
// app is cosmetic; these rules are the actual guarantee. Collections marked
// [FINANCE] must never be readable by the secretary.
//
// Deploy:  firebase deploy --only firestore:rules
// Test:    cd rules_tests && npm test   (runs against the emulator)
// =============================================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    function isSecretary() {
      return isSignedIn() && userRole() == 'secretary';
    }

    // The only two operating roles of the shop.
    function isStaff() {
      return isSignedIn() && userRole() in ['admin', 'secretary'];
    }

    // ---------- /users/{uid} --------------------------------------------------
    // No self-registration. The first admin is created once via the bootstrap
    // batch (users/{uid} + settings/bootstrap written together); after that,
    // only the admin can create accounts (e.g. the secretary's).

    match /users/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);

      // One-time bootstrap: a signed-in user may create their own admin doc
      // only while settings/bootstrap does not exist yet, and only if the
      // same batch creates it (getAfter sees the post-batch state).
      allow create: if isAdmin()
        || (isSignedIn()
            && request.auth.uid == uid
            && request.resource.data.role == 'admin'
            && !exists(/databases/$(database)/documents/settings/bootstrap)
            && getAfter(/databases/$(database)/documents/settings/bootstrap).data.done == true);

      // Admin updates anything; a user may update their own doc but never
      // change their role.
      allow update: if isAdmin()
        || (isSignedIn()
            && request.auth.uid == uid
            && request.resource.data.role == resource.data.role);

      allow delete: if isAdmin();
    }

    // ---------- /settings/{doc} ------------------------------------------------

    // Shop name + logo, shown on the login screen BEFORE authentication.
    match /settings/public {
      allow read: if true;
      allow write: if isAdmin();
    }

    // [FINANCE] default piece rate and other financial settings.
    match /settings/private {
      allow read, write: if isAdmin();
    }

    // Bootstrap marker: created exactly once, in the same batch as the first
    // admin user doc. Never updated or deleted afterwards.
    match /settings/bootstrap {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.done == true
        && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update, delete: if false;
    }

    // ---------- /clients/{clientId} --------------------------------------------
    // Plain records managed by the shop; clients are not app users.

    match /clients/{clientId} {
      allow read, create, update, delete: if isStaff();

      // Flexible per-garment measurements (key-value map).
      match /measurements/{measurementId} {
        allow read, create, update, delete: if isStaff();
      }
    }

    // ---------- /products/{productId} -------------------------------------------
    // Catalog is admin-managed. The secretary can read it (she sells at the
    // counter) and may ONLY decrement stock as part of a sale.

    match /products/{productId} {
      allow read: if isStaff();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (isSecretary()
            // Sale decrement only: single field, strictly decreasing, >= 0.
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['quantity'])
            && request.resource.data.quantity is int
            && request.resource.data.quantity < resource.data.quantity
            && request.resource.data.quantity >= 0);
    }

    // ---------- /sales/{saleId} [FINANCE — write-only for secretary] ------------
    // The secretary can REGISTER a sale (create) but can never read, list,
    // change or delete sales. Revenue history belongs to the manager alone.

    match /sales/{saleId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        || (isSecretary()
            && request.resource.data.kind in ['produit', 'pret_a_porter']
            && request.resource.data.qty is int
            && request.resource.data.qty > 0
            && request.resource.data.unitPrice is number
            && request.resource.data.unitPrice >= 0
            && request.resource.data.total == request.resource.data.qty * request.resource.data.unitPrice
            && request.resource.data.createdBy == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ---------- /staff/{staffId} -------------------------------------------------
    // Contact info ONLY (name, phone, type, joinedAt, active). Pay data lives
    // in /staff_pay and /tailor_daily_entries, which the secretary cannot read.

    match /staff/{staffId} {
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    // ---------- /staff_pay/{staffId} [FINANCE] -----------------------------------

    match /staff_pay/{staffId} {
      allow read, write: if isAdmin();
    }

    // ---------- /tailor_daily_entries/{entryId} [FINANCE] -------------------------
    // Immutable audit history: no deletes, ever. Updates only within 24h of
    // creation (same-day correction window).

    match /tailor_daily_entries/{entryId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.piecesCount is int
        && request.resource.data.piecesCount >= 0
        && request.resource.data.amount == request.resource.data.piecesCount * request.resource.data.pieceRate;
      allow update: if isAdmin()
        && request.time < resource.data.createdAt + duration.value(24, 'h')
        && request.resource.data.amount == request.resource.data.piecesCount * request.resource.data.pieceRate;
      allow delete: if false;
    }

    // ---------- /expenses/{expenseId} [FINANCE] -----------------------------------

    match /expenses/{expenseId} {
      allow read, write: if isAdmin();
    }

    // ---------- /pret_a_porter/{modelId} -------------------------------------------

    match /pret_a_porter/{modelId} {
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    // ---------- /orders/{orderId} ----------------------------------------------------
    // The secretary registers and manages orders daily (incl. price/advance —
    // she invoices clients at the counter). Aggregated revenue stays in the
    // [FINANCE] screens which she cannot query.

    match /orders/{orderId} {
      allow read: if isStaff();
      allow create, update: if isStaff()
        && request.resource.data.status in ['en_cours', 'pret', 'livre'];
      allow delete: if isAdmin();
    }

    // ---------- /appointments/{appointmentId} ------------------------------------------

    match /appointments/{appointmentId} {
      allow read, create, update, delete: if isStaff();
    }

    // ---------- /notifications/{id} -----------------------------------------------------
    // Internal staff notifications (e.g. low-stock alerts, reminders).

    match /notifications/{id} {
      allow read, create, update, delete: if isStaff();
    }

    // ---------- default deny -------------------------------------------------------------

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
