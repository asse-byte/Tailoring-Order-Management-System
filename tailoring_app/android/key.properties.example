# Copy to android/key.properties (gitignored) and fill in your real values.
# Generate the keystore ONCE and keep it safe forever — losing it means you can
# never ship an update to the same app id. See docs/DEPLOYMENT.md.
#
#   keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA \
#     -keysize 2048 -validity 10000 -alias upload
#
storePassword=CHANGE_ME
keyPassword=CHANGE_ME
keyAlias=upload
# Absolute path is safest, e.g. C:/keys/upload-keystore.jks
storeFile=CHANGE_ME/upload-keystore.jks
