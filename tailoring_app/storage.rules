// =============================================================================
// Couture Mali — Cloud Storage security rules
// =============================================================================
// Deploy with:    firebase deploy --only storage
//
//  • logo/{file}            ← shop logo, public read (login screen), admin write
//  • products/{id}/{file}   ← product images, staff read, admin write
//  • pret_a_porter/{id}/…   ← model images/videos, staff read, admin write
//  • orders/{orderId}/…     ← fabric/style photos attached to an order,
//                              staff read+write (secretary registers orders)
//
// Role checks piggy-back on the Firestore /users doc — same source of truth
// as firestore.rules.
// =============================================================================

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
        .data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    function isStaff() {
      return isSignedIn() && userRole() in ['admin', 'secretary'];
    }

    // Keep uploads sane: images/videos only, max 10 MB.
    function isReasonableMedia() {
      return request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('video/.*'));
    }

    // ---- Shop logo (shown pre-auth on the login screen) ---------------------
    match /logo/{file=**} {
      allow read: if true;
      allow write: if isAdmin() && isReasonableMedia();
    }

    // ---- Product images ------------------------------------------------------
    match /products/{productId}/{file=**} {
      allow read: if isStaff();
      allow write: if isAdmin() && isReasonableMedia();
    }

    // ---- Prêt-à-porter media (images + optional video) -----------------------
    match /pret_a_porter/{modelId}/{file=**} {
      allow read: if isStaff();
      allow write: if isAdmin() && isReasonableMedia();
    }

    // ---- Order photos (fabric, style references) ------------------------------
    match /orders/{orderId}/{file=**} {
      allow read: if isStaff();
      allow write: if isStaff() && isReasonableMedia();
    }

    // Everything else: denied by default.
  }
}
