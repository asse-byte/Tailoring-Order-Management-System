{
  "name": "couture-mali-api",
  "version": "1.0.0",
  "private": true,
  "description": "REST API for the Couture Mali tailoring shop — Express + PostgreSQL, two-role RBAC with server-enforced financial isolation.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node scripts/dev.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "reset-password": "node scripts/reset-password.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jimp": "^1.6.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "embedded-postgres": "^18.4.0-beta.17",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
